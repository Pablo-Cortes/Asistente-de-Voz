<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Aura Voice Hybrid</title>
    <style>
        :root {
            --bg: #0a0a0c;
            --accent: #00d4ff;
            --secondary: #7000ff;
            --glass: rgba(255, 255, 255, 0.05);
            --border: rgba(255, 255, 255, 0.1);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; outline: none; }

        body {
            background-color: var(--bg);
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(0, 212, 255, 0.1) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(112, 0, 255, 0.1) 0%, transparent 40%);
            color: white;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow: hidden;
        }

        .container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        /* Cabecera */
        header {
            text-align: center;
            padding: 20px 0;
        }

        h1 {
            font-size: 1.2rem;
            font-weight: 300;
            letter-spacing: 4px;
            margin: 0;
            text-transform: uppercase;
            background: linear-gradient(to right, var(--accent), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Zona de visualización central */
        .visualizer-zone {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .aura-circle {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: var(--bg);
            border: 2px solid var(--border);
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            z-index: 2;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            cursor: pointer;
        }

        .aura-circle.listening {
            border-color: var(--accent);
            box-shadow: 0 0 40px var(--accent);
            transform: scale(1.05);
        }

        .aura-circle.speaking {
            border-color: var(--secondary);
            box-shadow: 0 0 40px var(--secondary);
        }

        .glow-ring {
            position: absolute;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0;
            z-index: 1;
            transition: 0.5s;
        }

        .listening + .glow-ring {
            opacity: 0.2;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.3; }
            100% { transform: scale(1.5); opacity: 0; }
        }

        /* Caja de Texto */
        .input-card {
            background: var(--glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 15px;
            margin-bottom: 20px;
        }

        textarea {
            width: 100%;
            height: 100px;
            background: transparent;
            border: none;
            color: #ddd;
            font-size: 1rem;
            resize: none;
            text-align: center;
        }

        /* Controles Inferiores */
        .toolbar {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 15px;
        }

        button {
            background: var(--glass);
            border: 1px solid var(--border);
            color: white;
            padding: 14px;
            border-radius: 16px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: 0.2s;
        }

        button:active { transform: scale(0.95); background: rgba(255,255,255,0.1); }

        .btn-primary {
            background: white;
            color: black;
            font-weight: bold;
        }

        .mode-toggle {
            grid-column: span 2;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            font-size: 0.8rem;
            color: #888;
        }

        /* Selector de voces custom */
        .voice-picker {
            width: 100%;
            background: transparent;
            color: var(--accent);
            border: none;
            font-size: 0.75rem;
            text-align: center;
            margin-top: 10px;
            opacity: 0.6;
        }

        .status-pill {
            position: absolute;
            top: -40px;
            font-size: 0.7rem;
            letter-spacing: 2px;
            color: var(--accent);
            text-transform: uppercase;
        }

        /* Switch */
        .switch {
            position: relative;
            display: inline-block;
            width: 34px;
            height: 20px;
        }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #333;
            transition: .4s;
            border-radius: 34px;
        }
        .slider:before {
            position: absolute; content: "";
            height: 14px; width: 14px; left: 3px; bottom: 3px;
            background-color: white; transition: .4s; border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--accent); }
        input:checked + .slider:before { transform: translateX(14px); }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>Aura Hybrid</h1>
        </header>

        <div class="visualizer-zone">
            <div id="status" class="status-pill">Ready</div>
            <div id="main-circle" class="aura-circle">
                <span id="center-icon" style="font-size: 3rem;">🎙️</span>
            </div>
            <div class="glow-ring"></div>
        </div>

        <div class="input-card">
            <textarea id="text-input" placeholder="Escribe para leer o usa el micro..."></textarea>
            <select id="voice-select" class="voice-picker">
                <option value="">Cargando voces...</option>
            </select>
        </div>

        <div class="toolbar">
            <button id="btn-read" class="btn-primary">
                <span>🔊</span> Leer Texto
            </button>
            <button id="btn-clear">
                <span>🗑️</span> Limpiar
            </button>
            
            <div class="mode-toggle">
                <span>MODO ECO AUTOMÁTICO</span>
                <label class="switch">
                    <input type="checkbox" id="echo-mode">
                    <span class="slider"></span>
                </label>
            </div>
        </div>
    </div>

    <script>
        const mainCircle = document.getElementById('main-circle');
        const centerIcon = document.getElementById('center-icon');
        const textInput = document.getElementById('text-input');
        const btnRead = document.getElementById('btn-read');
        const btnClear = document.getElementById('btn-clear');
        const voiceSelect = document.getElementById('voice-select');
        const echoMode = document.getElementById('echo-mode');
        const status = document.getElementById('status');

        const synth = window.speechSynthesis;
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        let recognition = null;
        let voices = [];
        let isListening = false;

        // --- CONFIGURACIÓN TTS (Texto a Voz) ---
        function loadVoices() {
            voices = synth.getVoices();
            if (voices.length === 0) return;
            
            voiceSelect.innerHTML = voices
                .filter(v => v.lang.includes('es') || v.lang.includes('en'))
                .map(v => `<option value="${v.name}">${v.name} (${v.lang})</option>`)
                .join('');
        }
        
        synth.onvoiceschanged = loadVoices;
        setInterval(() => { if(voices.length === 0) loadVoices() }, 1000);

        function speak(text) {
            if (!text) return;
            synth.cancel();
            const utter = new SpeechSynthesisUtterance(text);
            const voice = voices.find(v => v.name === voiceSelect.value);
            if (voice) utter.voice = voice;

            utter.onstart = () => {
                mainCircle.classList.add('speaking');
                centerIcon.textContent = "📢";
                status.textContent = "Reproduciendo";
            };
            utter.onend = () => {
                mainCircle.classList.remove('speaking');
                centerIcon.textContent = "🎙️";
                status.textContent = "Ready";
            };
            synth.speak(utter);
        }

        // --- CONFIGURACIÓN STT (Voz a Texto) ---
        if (SpeechRecognition) {
            recognition = new SpeechRecognition();
            recognition.continuous = false;
            
            recognition.onstart = () => {
                isListening = true;
                mainCircle.classList.add('listening');
                centerIcon.textContent = "👂";
                status.textContent = "Escuchando";
            };

            recognition.onresult = (event) => {
                const transcript = event.results[0][0].transcript;
                textInput.value = transcript;
                if (echoMode.checked) {
                    setTimeout(() => speak(transcript), 600);
                }
            };

            recognition.onend = () => {
                isListening = false;
                mainCircle.classList.remove('listening');
                if (!synth.speaking) {
                    centerIcon.textContent = "🎙️";
                    status.textContent = "Ready";
                }
            };
        }

        // --- EVENTOS ---
        
        // Al tocar el círculo: Inicia escucha (Voz a Texto)
        mainCircle.onclick = () => {
            if (isListening) {
                recognition.stop();
            } else {
                synth.cancel();
                recognition.start();
            }
            if (navigator.vibrate) navigator.vibrate(15);
        };

        // Al pulsar Leer Texto (Escritura a Voz)
        btnRead.onclick = () => {
            speak(textInput.value);
            if (navigator.vibrate) navigator.vibrate(15);
        };

        btnClear.onclick = () => {
            textInput.value = '';
            synth.cancel();
        };

        // Evitar comportamientos extraños en móvil
        document.addEventListener('touchmove', (e) => {
            if (e.scale !== 1) e.preventDefault();
        }, { passive: false });
    </script>
</body>
</html>
